{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@repo/auth": ["packages/auth/src/index.ts"],
      "@repo/booking": ["packages/booking/src/index.ts"],
      "@repo/config": ["packages/config/src/index.ts"],
      "@repo/database": ["packages/database/src/index.ts"],
      "@repo/notifications": ["packages/notifications/src/index.ts"],
      "@repo/types": ["packages/types/src/index.ts"],
      "@repo/ui": ["packages/ui/src/index.ts"],
      "@repo/validation": ["packages/validation/src/index.ts"]
    }
  }
}
